# --- LINE（必須）---
# LINE Developersで発行した「チャネルアクセストークン（長期）」
LINE_CHANNEL_ACCESS_TOKEN=
# 公式アカウントマネージャーのMessaging API画面に表示される Channel secret（署名検証に使用）
LINE_CHANNEL_SECRET=
# Channel ID（Supabase接続時、トークンの自動更新に使用）
LINE_CHANNEL_ID=

# --- AI（必須）: Claude / Anthropic ---
# console.anthropic.com で発行するAPIキー（sk-ant-...）
ANTHROPIC_API_KEY=
# 使うモデル（未設定なら claude-opus-4-8）。コスト重視なら claude-sonnet-4-6
ANTHROPIC_MODEL=claude-opus-4-8

# --- Supabase（推奨・会話記憶と相談ログの保存に使用）---
# 未設定でも動くが、会話の記憶はサーバー再起動で消える（動作確認用）
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- 緊急エスカレーション（人へつなぐ）---
# Slackの Incoming Webhook URL（運営の主アラート先。おすすめ）
SLACK_WEBHOOK_URL=
# 通知を受け取る運営のLINEユーザーID/グループID（カンマ区切りで複数可）
OPERATOR_LINE_USER_IDS=
# 有人テイクオーバー（緊急時にBotが引いて人がLINEチャットで対応）を使うなら true
ENABLE_HUMAN_TAKEOVER=false
# テイクオーバーの継続時間（時間）。この時間を過ぎると自動でBot対応に戻る
HUMAN_MODE_HOURS=12

# --- レポートAPI（運営専用）---
# /api/report のアクセストークン（任意の長い文字列。これを知る人だけ集計を見られる）
REPORT_ACCESS_TOKEN=
