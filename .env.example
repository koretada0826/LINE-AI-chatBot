# --- LINE（必須）---
# LINE Developersで発行した「チャネルアクセストークン（長期）」
LINE_CHANNEL_ACCESS_TOKEN=
# 公式アカウントマネージャーのMessaging API画面に表示される Channel secret（署名検証に使用）
LINE_CHANNEL_SECRET=

# --- AI（必須）: Gemini / Google AI Studio ---
# aistudio.google.com で発行するAPIキー
GEMINI_API_KEY=
# 使うモデル（未設定なら gemini-2.5-flash）。品質重視なら gemini-2.5-pro
GEMINI_MODEL=gemini-2.5-flash

# --- Supabase（推奨・会話記憶と相談ログの保存に使用）---
# 未設定でも動くが、会話の記憶はサーバー再起動で消える（動作確認用）
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- 緊急エスカレーション（人へつなぐ）---
# Slackの Incoming Webhook URL（運営の主アラート先。おすすめ）
SLACK_WEBHOOK_URL=
# 通知を受け取る運営のLINEユーザーID/グループID（カンマ区切りで複数可）
OPERATOR_LINE_USER_IDS=
# 有人テイクオーバー（緊急時にBotが引いて人がLINEチャットで対応）を使うなら true
ENABLE_HUMAN_TAKEOVER=false
# テイクオーバーの継続時間（時間）。この時間を過ぎると自動でBot対応に戻る
HUMAN_MODE_HOURS=12
